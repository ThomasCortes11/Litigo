// ============================================================
// Litigo - Esquema de base de datos
// PostgreSQL + Prisma
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------
// Autenticacion / administracion interna
// ----------------------------------------------------------

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique // SUPERADMIN | ADMIN | ANALYST
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@map("roles")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  email        String    @unique
  passwordHash String
  isActive     Boolean   @default(true)
  roleId       String    @db.Uuid
  role         Role      @relation(fields: [roleId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  auditLogs AuditLog[]

  @@index([email])
  @@index([roleId])
  @@map("users")
}

// ----------------------------------------------------------
// Afiliados / membresias
// ----------------------------------------------------------

enum AffiliateStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Affiliate {
  id             String          @id @default(uuid()) @db.Uuid
  fullName       String
  documentType   String // CC | CE | PASAPORTE
  documentNumber String          @unique
  email          String
  phone          String
  city           String
  status         AffiliateStatus @default(PENDING)
  affiliateCode  String?         @unique

  acceptedContractAt    DateTime?
  acceptedTermsAt       DateTime?
  acceptedDataPolicyAt  DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  memberships Membership[]
  payments    Payment[]

  @@index([status])
  @@index([email])
  @@index([createdAt])
  @@map("affiliates")
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model Membership {
  id          String           @id @default(uuid()) @db.Uuid
  affiliateId String           @db.Uuid
  affiliate   Affiliate        @relation(fields: [affiliateId], references: [id])
  planName    String           @default("Membresia Litigo Mensual")
  value       Decimal          @db.Decimal(12, 2)
  startDate   DateTime         @default(now())
  endDate     DateTime
  status      MembershipStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  payments Payment[]

  @@index([affiliateId])
  @@index([status])
  @@map("memberships")
}

enum PaymentStatus {
  PENDING
  APPROVED
  DECLINED
  ERROR
  VOIDED
}

model Payment {
  id                 String        @id @default(uuid()) @db.Uuid
  affiliateId        String        @db.Uuid
  affiliate          Affiliate     @relation(fields: [affiliateId], references: [id])
  membershipId       String?       @db.Uuid
  membership         Membership?   @relation(fields: [membershipId], references: [id])
  reference          String        @unique
  wompiTransactionId String?       @unique
  amount             Decimal       @db.Decimal(12, 2)
  currency           String        @default("COP")
  status             PaymentStatus @default(PENDING)
  paymentMethod      String?
  rawResponse        Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([affiliateId])
  @@index([status])
  @@index([reference])
  @@map("payments")
}

// ----------------------------------------------------------
// Documentos legales / configuracion
// ----------------------------------------------------------

enum LegalDocumentType {
  TERMS
  CONTRACT
  DATA_POLICY
}

model LegalDocument {
  id        String            @id @default(uuid()) @db.Uuid
  type      LegalDocumentType
  version   Int               @default(1)
  title     String
  content   String            @db.Text
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([type, isActive])
  @@map("legal_documents")
}

model Setting {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

// ----------------------------------------------------------
// Auditoria
// ----------------------------------------------------------

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @db.Uuid
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String // ej: AFFILIATE_ACTIVATED, SETTINGS_UPDATED
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
