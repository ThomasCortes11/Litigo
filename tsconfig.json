{
  "compilerOptions": {
    /* ── Objetivo de compilacion ── */
    "target":              "ES2017",
    "lib":                 ["dom", "dom.iterable", "esnext"],
    "module":              "esnext",
    "moduleResolution":    "bundler",

    /* ── Interoperabilidad ── */
    "esModuleInterop":     true,
    "resolveJsonModule":   true,
    "isolatedModules":     true,
    "allowJs":             false,
    "skipLibCheck":        true,

    /* ── Modo estricto ── */
    "strict":                          true,
    "noUncheckedIndexedAccess":        true,
    "noImplicitReturns":               true,
    "noFallthroughCasesInSwitch":      true,

    /* ── Output ── */
    "noEmit":              true,
    "incremental":         true,

    /* ── Next.js ── */
    "jsx":                 "preserve",
    "plugins":             [{ "name": "next" }],

    /* ── Path aliases ── */
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
