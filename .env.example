# ══════════════════════════════════════════════
#  Litigo — Variables de entorno
#  Copia este archivo como .env y completa los valores
#  NUNCA subas .env al repositorio (ya está en .gitignore)
# ══════════════════════════════════════════════


# ── Base de datos ──────────────────────────────
# Formato: postgresql://USUARIO:CONTRASENA@HOST:PUERTO/NOMBRE_BD
# Local:   postgresql://postgres:miClave@localhost:5432/litigo
# Neon:    lo encuentras en tu dashboard en neon.tech
DATABASE_URL="postgresql://usuario:password@localhost:5432/litigo?schema=public"


# ── Auth.js ────────────────────────────────────
# Genera el secreto con: npx auth secret
# Debe tener mínimo 32 caracteres aleatorios
AUTH_SECRET="reemplaza-con-un-secreto-generado-por-npx-auth-secret"
AUTH_URL="http://localhost:3000"


# ── Wompi — Pasarela de pagos ──────────────────
# Obtén tus llaves en: https://comercios.wompi.co/sandbox
# Para producción: https://comercios.wompi.co
WOMPI_PUBLIC_KEY="pub_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
WOMPI_PRIVATE_KEY="prv_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
WOMPI_EVENTS_SECRET="test_events_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
WOMPI_INTEGRITY_SECRET="test_integrity_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Sandbox: https://sandbox.wompi.co/v1
# Producción: https://production.wompi.co/v1
WOMPI_API_URL="https://sandbox.wompi.co/v1"


# ── Resend — Correos transaccionales ──────────
# Obtén tu API key en: https://resend.com
# El dominio del FROM debe estar verificado en Resend
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Litigo <afiliaciones@litigo.com.co>"


# ── Vercel Blob — Almacenamiento de archivos ──
# Se genera automáticamente al activar Blob en el dashboard de Vercel
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"


# ── Aplicación ────────────────────────────────
# En local: http://localhost:3000
# En producción: https://tu-dominio.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Litigo"
