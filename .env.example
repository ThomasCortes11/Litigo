# ===== Base de datos =====
DATABASE_URL="postgresql://usuario:password@localhost:5432/litigo?schema=public"

# ===== Auth.js =====
# Generar con: npx auth secret   (o: openssl rand -base64 32)
AUTH_SECRET="reemplaza-este-valor-por-uno-generado"
AUTH_URL="http://localhost:3000"

# ===== Wompi (pasarela de pagos) =====
# Sandbox: https://comercios.wompi.co/sandbox
WOMPI_PUBLIC_KEY="pub_test_xxxxxxxxxxxxxxxxxxxx"
WOMPI_PRIVATE_KEY="prv_test_xxxxxxxxxxxxxxxxxxxx"
WOMPI_EVENTS_SECRET="test_events_xxxxxxxxxxxxxxxxxxxx"
WOMPI_INTEGRITY_SECRET="test_integrity_xxxxxxxxxxxxxxxxxxxx"
WOMPI_API_URL="https://sandbox.wompi.co/v1"

# ===== Resend (correos transaccionales) =====
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Litigo <afiliaciones@litigo.com.co>"

# ===== Vercel Blob (almacenamiento de archivos) =====
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"

# ===== Aplicacion =====
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Litigo"
