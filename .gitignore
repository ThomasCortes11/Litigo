# ══════════════════════════════════════════════
#  Litigo — .gitignore
# ══════════════════════════════════════════════

# ── Variables de entorno (NUNCA subir al repo) ──
.env
.env.local
.env.*.local

# ── Next.js ──
.next/
out/

# ── Node ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build ──
build/
dist/

# ── Prisma ──
prisma/migrations/dev.db

# ── TypeScript ──
*.tsbuildinfo
next-env.d.ts

# ── Vercel ──
.vercel

# ── Sistema operativo ──
.DS_Store
Thumbs.db
*.pem
